# ───────────────────────────────────────────────────────────────────
# p-fit · env
# Copy to .env.local (gitignored) and fill in.
# Leave VITE_SUPABASE_* empty to use the localStorage adapter.
# ───────────────────────────────────────────────────────────────────

# Option A — Local Supabase (after `npm run db:start`)
# Defaults printed by `supabase start`; the keys below are the public
# locals from the Supabase CLI and are NOT secret.
# VITE_SUPABASE_URL=http://127.0.0.1:54321
# VITE_SUPABASE_ANON_KEY=<paste from `supabase status` output>

# Option B — Hosted Supabase
# VITE_SUPABASE_URL=https://<project-ref>.supabase.co
# VITE_SUPABASE_ANON_KEY=<anon key from Supabase dashboard>

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
